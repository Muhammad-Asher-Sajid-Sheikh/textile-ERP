# ============================================================================
# TEXTILE ERP - Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in the actual values

# ============================================================================
# 1. DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/textile_erp"

# ============================================================================
# 2. JWT SECRETS (Generate strong secrets - use 64+ character random strings)
# ============================================================================
# You can generate secrets using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Access token secret (used for short-lived tokens - 15 minutes)
JWT_ACCESS_SECRET="your-super-secret-access-key-here-min-64-characters"

# Refresh token secret (used for long-lived tokens - 7 days)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here-min-64-characters"

# ============================================================================
# 3. EMAIL SERVICE (RESEND.COM)
# ============================================================================
# Get your API key from https://resend.com

# Resend API Key
ResendAPIKey="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email address to send from (must be verified in Resend dashboard)
RESEND_FROM_EMAIL="noreply@yourcompany.com"

# Frontend login URL (used in email templates)
FRONTEND_LOGIN_URL="https://yourfrontend.com/login"

# ============================================================================
# 4. APPLICATION CONFIGURATION
# ============================================================================
# Environment: development, staging, production
NODE_ENV="development"

# Server port
PORT="3000"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# ============================================================================
# 5. SECURITY CONFIGURATION
# ============================================================================
# Rate limiting - requests per window
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"  # max requests per window

# Account lockout settings
ACCOUNT_LOCKOUT_ATTEMPTS="5"    # Lock after 5 failed attempts
ACCOUNT_LOCKOUT_DURATION_MS="900000"  # Lock for 15 minutes

# ============================================================================
# 6. DATABASE BACKUP & MAINTENANCE
# ============================================================================
# Enable automatic cleanup of expired refresh tokens
ENABLE_TOKEN_CLEANUP="true"
TOKEN_CLEANUP_INTERVAL_MS="3600000"  # Run every hour

# ============================================================================
# 7. LOGGING (Optional)
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Enable request logging
ENABLE_REQUEST_LOGGING="true"
